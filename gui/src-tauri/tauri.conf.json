{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Latch",
  "version": "0.1.3",
  "identifier": "com.vacantsystems.latch",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5175",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "Latch",
        "visible": false,
        "width": 700,
        "height": 440,
        "minWidth": 700,
        "minHeight": 440,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "transparent": true,
        "backgroundColor": "#00000000"
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "windows": {
      "nsis": {
        "installMode": "perMachine",
        "installerIcon": "icons/icon.ico",
        "startMenuFolder": "Vacant Systems",
        "installerHooks": "nsis-hooks.nsh"
      }
    },
    "resources": ["coredist/**/*", "resources/ytdlp/**/*", "resources/ffmpeg/**/*"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
